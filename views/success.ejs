<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Ticket Created</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><div class="card"><h1>✅ Ticket Created</h1><p>Your Ticket ID: <strong><%= ticketId %></strong></p><p class="small">Status token: <code><%= shortToken %>...</code></p><p><a class="btn" href="<%= statusUrl %>">Open Status Page</a></p><p><button class="btn secondary" onclick="navigator.clipboard.writeText('<%= statusUrl %>')">Copy Status Link</button></p><p class="small">Keep this link safe. You can also check with Ticket ID + Employee ID.</p><a class="btn secondary" href="/submit">Create another ticket</a></div></div></body></html>