<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Ticket Created</title><link rel="stylesheet" href="/public/styles.css"></head><body><canvas id="confetti" style="position:fixed;inset:0 auto auto 0;pointer-events:none;z-index:2"></canvas><div class="container"><%- include('partials_top') %><div class="card fade-up"><h1>Ticket Created 🎉</h1><p>Your Ticket ID: <strong><%= ticketId %></strong></p><p class="small">Status token: <code><%= shortToken %>...</code></p><p><a class="btn" href="<%= statusUrl %>">Open Status Page</a> <button class="btn secondary" onclick="navigator.clipboard.writeText('<%= statusUrl %>')">Copy Status Link</button></p><p class="small">Keep the status link safe. You can also use Ticket ID + Employee ID on the status page.</p><a class="btn secondary" href="/submit">Create another ticket</a></div></div><script src="/public/app.js"></script></body></html>