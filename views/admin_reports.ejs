<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Reports</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><%- include('partials_top') %><a class="btn secondary" href="/admin">← Back to Dashboard</a><div class="card" style="margin-top:12px"><h1>Reports</h1><p class="small">Operational metrics for response and resolution performance.</p><div class="kpi"><div class="card"><div class="small">Avg First Response</div><div class="metric"><%= Number(kpi.avg_first_response_hours || 0).toFixed(2) %>h</div></div><div class="card"><div class="small">Avg Resolution</div><div class="metric"><%= Number(kpi.avg_resolution_hours || 0).toFixed(2) %>h</div></div></div><h3>Tickets by Category</h3><ul><% byCategory.forEach(r => { %><li><%= r.category %>: <strong><%= r.count %></strong></li><% }) %></ul></div></div></body></html>