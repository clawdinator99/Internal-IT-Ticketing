<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Reports</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><a class="btn secondary" href="/admin">← Back</a><div class="card" style="margin-top:12px"><h1>Basic Reports</h1><div class="kpi"><div class="card"><h3>Avg First Response</h3><p><%= Number(kpi.avg_first_response_hours || 0).toFixed(2) %> hrs</p></div><div class="card"><h3>Avg Resolution</h3><p><%= Number(kpi.avg_resolution_hours || 0).toFixed(2) %> hrs</p></div></div><h3>Tickets by Category</h3><ul><% byCategory.forEach(r => { %><li><%= r.category %>: <strong><%= r.count %></strong></li><% }) %></ul></div></div></body></html>