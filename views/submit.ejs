<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Raise IT Ticket</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><%- include('partials_top') %>
<div class="card fade-up">
  <h1>Raise an IT Ticket</h1>
  <p class="small">No account. No friction. Under 60 seconds.</p>
  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <form method="post" action="/submit" class="grid">
    <div><label>Name *</label><input name="submitter_name" required value="<%= values.submitter_name || '' %>"></div>
    <div><label>Employee ID *</label><input name="employee_id" required value="<%= values.employee_id || '' %>"></div>
    <div><label>Email *</label><input type="email" name="email" required value="<%= values.email || '' %>"></div>
    <div><label>Issue Category *</label><select name="category" required><option>Laptop</option><option>Mouse</option><option>Charger / Power</option><option>Network / Wi‑Fi</option><option>Request: New IT asset</option><option>Other</option></select></div>
    <div><label>Urgency *</label><select name="priority" required><option>Low</option><option>Medium</option><option>High</option></select></div>
    <div class="full"><label>Short summary *</label><input name="summary" required maxlength="120" placeholder="One-line summary"></div>
    <div class="full"><label>Description *</label><textarea name="description" rows="4" required placeholder="What happened? What did you already try?"><%= values.description || '' %></textarea></div>
    <div class="full"><button type="submit">Create Ticket</button></div>
  </form>
</div></div><script src="/public/app.js"></script></body></html>