<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Ticket Status Lookup</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><%- include('partials_top') %><div class="card fade-up"><h1>Track a Ticket</h1><p class="small">Use Ticket ID + Employee ID to check live status.</p><form method="post" action="/status" class="grid"><div><label>Ticket ID</label><input name="ticket_id" required placeholder="IT-2026-0234"></div><div><label>Employee ID</label><input name="employee_id" required></div><div class="full"><button type="submit">Check Status</button></div></form><% if (error) { %><div class="error" style="margin-top:12px"><%= error %></div><% } %>
<% if (ticket) { %><hr><div class="status-hero"><div><h2><%= ticket.ticket_id %></h2><p class="small"><strong><%= ticket.summary %></strong></p></div><div><span class="badge status-<%= ticket.status %>"><%= ticket.status %></span></div></div><div class="status-metrics"><div class="metric-card"><div class="small">Category</div><div><%= ticket.category %></div></div><div class="metric-card"><div class="small">Priority</div><div><%= ticket.priority %></div></div><div class="metric-card"><div class="small">Last Updated (IST)</div><div><%= fmt(ticket.updated_at) %></div></div></div><h3>Activity</h3><ul class="timeline"><% ticket.audit.forEach(a => { %><li><strong><%= a.action %></strong> <span class="small">(<%= fmt(a.created_at) %>)</span> <% if (a.note) { %><div><%= a.note %></div><% } %></li><% }) %></ul><% } %>
</div></div><script src="/public/app.js"></script></body></html>