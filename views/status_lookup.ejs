<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Ticket Status Lookup</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><div class="card"><h1>Check Ticket Status</h1><form method="post" action="/status" class="grid"><div><label>Ticket ID</label><input name="ticket_id" required placeholder="IT-2026-0234"></div><div><label>Employee ID</label><input name="employee_id" required></div><div class="full"><button type="submit">Check Status</button> <a class="btn secondary" href="/submit">Raise new ticket</a></div></form><% if (error) { %><div class="error" style="margin-top:12px"><%= error %></div><% } %>
<% if (ticket) { %><hr><h2><%= ticket.ticket_id %> — <span class="badge status-<%= ticket.status %>"><%= ticket.status %></span></h2><p><strong><%= ticket.summary %></strong></p><p class="small">Category: <%= ticket.category %> • Priority: <%= ticket.priority %> • Updated: <%= ticket.updated_at %></p><h3>Activity</h3><ul class="timeline"><% ticket.audit.forEach(a => { %><li><strong><%= a.action %></strong> <span class="small">(<%= a.created_at %>)</span> <% if (a.note) { %><div><%= a.note %></div><% } %></li><% }) %></ul><% } %>
</div></div></body></html>