<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= ticket.ticket_id %></title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><%- include('partials_top') %><a class="btn secondary" href="/admin">← Back</a><div class="layout" style="margin-top:12px"><main class="card"><h1><%= ticket.ticket_id %> <span class="badge status-<%= ticket.status %>"><%= ticket.status %></span></h1><p><strong><%= ticket.summary %></strong></p><p><%= ticket.description %></p><p class="small">Submitter: <%= ticket.submitter_name %> (<%= ticket.employee_id %>) • <%= ticket.department %> • <%= ticket.location %></p><h3>Attachments</h3><ul><% attachments.forEach(a => { %><li><a href="/uploads/<%= a.stored_name %>" target="_blank"><%= a.original_name %></a> (<%= Math.round(a.size/1024) %> KB)</li><% }) %></ul><h3>Audit Log</h3><ul class="timeline"><% audit.forEach(a => { %><li><strong><%= a.action %></strong> <span class="small">(<%= a.created_at %>)</span> <% if (a.from_value || a.to_value) { %><div class="small"><%= a.from_value || '-' %> → <%= a.to_value || '-' %></div><% } %> <% if (a.note) { %><div><%= a.note %></div><% } %></li><% }) %></ul></main>
<aside class="card sidebar"><h3>Update Ticket</h3><form method="post" action="/admin/ticket/<%= ticket.ticket_id %>/update"><label>Status</label><select name="status"><option <%= ticket.status==='New'?'selected':'' %>>New</option><option <%= ticket.status==='Triaged'?'selected':'' %>>Triaged</option><option <%= ticket.status==='In Progress'?'selected':'' %>>In Progress</option><option <%= ticket.status==='Waiting for User'?'selected':'' %>>Waiting for User</option><option <%= ticket.status==='Resolved'?'selected':'' %>>Resolved</option><option <%= ticket.status==='Closed'?'selected':'' %>>Closed</option></select><label>Assignee</label><input name="assignee" value="<%= ticket.assignee || '' %>" placeholder="Technician name"><label>Internal note</label><textarea name="note" rows="4" placeholder="Add internal update"></textarea><br><button type="submit">Save Changes</button></form><hr><h3>Internal Notes</h3><ul><% notes.forEach(n => { %><li><strong><%= n.author %>:</strong> <%= n.note %><div class="small"><%= n.created_at %></div></li><% }) %></ul></aside></div></div><script src="/public/app.js"></script></body></html>