<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= ticket.ticket_id %> Status</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><%- include('partials_top') %><div class="card fade-up"><div class="status-hero"><div><h1><%= ticket.ticket_id %></h1><p class="small"><strong><%= ticket.summary %></strong></p></div><div><span class="badge status-<%= ticket.status %>"><%= ticket.status %></span></div></div><div class="status-metrics"><div class="metric-card"><div class="small">Category</div><div><%= ticket.category %></div></div><div class="metric-card"><div class="small">Priority</div><div><%= ticket.priority %></div></div><div class="metric-card"><div class="small">Last Updated (IST)</div><div><%= fmt(ticket.updated_at) %></div></div><div class="metric-card"><div class="small">SLA Due (IST)</div><div><%= fmt(ticket.sla_due_at) %></div></div></div><h3>Timeline</h3><ul class="timeline"><% ticket.audit.forEach(a => { %><li><strong><%= a.action %></strong> <span class="small">(<%= fmt(a.created_at) %>)</span> <% if (a.note) { %><div><%= a.note %></div><% } %></li><% }) %></ul></div></div><script src="/public/app.js"></script></body></html>