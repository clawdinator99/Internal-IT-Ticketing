<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title><%= ticket.ticket_id %> Status</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><div class="card"><h1><%= ticket.ticket_id %></h1><p><span class="badge status-<%= ticket.status %>"><%= ticket.status %></span></p><p><strong><%= ticket.summary %></strong></p><p class="small">Priority: <%= ticket.priority %> • Category: <%= ticket.category %> • SLA Due: <%= ticket.sla_due_at %></p><h3>Timeline</h3><ul class="timeline"><% ticket.audit.forEach(a => { %><li><strong><%= a.action %></strong> <span class="small">(<%= a.created_at %>)</span> <% if (a.note) { %><div><%= a.note %></div><% } %></li><% }) %></ul><a class="btn secondary" href="/status">Lookup another ticket</a></div></div></body></html>