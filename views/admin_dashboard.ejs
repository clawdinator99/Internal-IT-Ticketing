<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body>
  <div class="container">
    <%- include('partials_top') %>

    <div class="kpi">
      <div class="card"><div class="small">Total Tickets</div><div class="metric"><%= kpi.total %></div></div>
      <div class="card"><div class="small">High Priority</div><div class="metric"><%= kpi.high %></div></div>
      <div class="card"><div class="small">In Progress</div><div class="metric"><%= kpi.inProgress %></div></div>
      <div class="card"><div class="small">Resolved / Closed</div><div class="metric"><%= kpi.resolved %></div></div>
    </div>

    <div class="layout">
      <aside class="card sidebar">
        <h3>Filters</h3>
        <form method="get" action="/admin">
          <label>Status</label>
          <select name="status">
            <option value="" <%= !filters.status ? 'selected' : '' %>>All</option>
            <option value="New" <%= filters.status==='New'?'selected':'' %>>New</option>
            <option value="In Progress" <%= filters.status==='In Progress'?'selected':'' %>>In Progress</option>
            <option value="Resolved" <%= filters.status==='Resolved'?'selected':'' %>>Resolved</option>
            <option value="Closed" <%= filters.status==='Closed'?'selected':'' %>>Closed</option>
          </select>

          <label>Category</label>
          <select name="category">
            <option value="" <%= !filters.category ? 'selected' : '' %>>All</option>
            <option value="Laptop" <%= filters.category==='Laptop'?'selected':'' %>>Laptop</option>
            <option value="Mouse" <%= filters.category==='Mouse'?'selected':'' %>>Mouse</option>
            <option value="Charger / Power" <%= filters.category==='Charger / Power'?'selected':'' %>>Charger / Power</option>
            <option value="Network / Wi-Fi" <%= filters.category==='Network / Wi-Fi'?'selected':'' %>>Network / Wi-Fi</option>
            <option value="Request: New IT asset" <%= filters.category==='Request: New IT asset'?'selected':'' %>>Request: New IT asset</option>
            <option value="Other" <%= filters.category==='Other'?'selected':'' %>>Other</option>
          </select>

          <label>Priority</label>
          <select name="priority">
            <option value="" <%= !filters.priority ? 'selected' : '' %>>All</option>
            <option <%= filters.priority==='Low'?'selected':'' %>>Low</option>
            <option <%= filters.priority==='Medium'?'selected':'' %>>Medium</option>
            <option <%= filters.priority==='High'?'selected':'' %>>High</option>
          </select>

          <label>Search</label>
          <input name="q" value="<%= filters.q %>" placeholder="ID / summary / submitter">

          <br><br>
          <button type="submit">Apply</button>
          <a class="btn secondary" href="/admin" style="margin-left:8px">Reset</a>
        </form>

        <hr>
        <p><a href="/admin/logout">Logout</a></p>
      </aside>

      <main class="card">
        <h1>Ticket Operations</h1>
        <p class="small">Detailed list with all key ticket fields for quick triage and follow-up.</p>

        <div style="overflow-x:auto; margin-top:10px">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Summary</th>
                <th>Requester</th>
                <th>Email</th>
                <th>Category</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Created</th>
                <th>Updated</th>
              </tr>
            </thead>
            <tbody>
              <% if (!tickets.length) { %>
                <tr><td colspan="9" class="small">No tickets match current filters.</td></tr>
              <% } %>
              <% tickets.forEach(t => { %>
                <tr>
                  <td><a href="/admin/ticket/<%= t.ticket_id %>"><strong><%= t.ticket_id %></strong></a></td>
                  <td><%= t.summary %></td>
                  <td><%= t.submitter_name %> (<%= t.employee_id %>)</td>
                  <td><%= t.email || '-' %></td>
                  <td><%= t.category %></td>
                  <td><%= t.priority %></td>
                  <td><span class="badge status-<%= t.status %>"><%= t.status %></span></td>
                  <td><%= fmt(t.created_at) %></td>
                  <td><%= fmt(t.updated_at) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </main>
    </div>
  </div>
</body>
</html>
