<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>Admin Dashboard</title><link rel="stylesheet" href="/public/styles.css"></head><body><div class="container"><div class="layout"><aside class="card sidebar"><h3>Filters</h3><form method="get" action="/admin">
<label>Status</label><select name="status"><option value="">All</option><option>New</option><option>Triaged</option><option>In Progress</option><option>Waiting for User</option><option>Resolved</option><option>Closed</option></select>
<label>Category</label><select name="category"><option value="">All</option><option>Laptop</option><option>Mouse</option><option>Charger / Power</option><option>Network / Wi‑Fi</option><option>Request: New IT asset</option><option>Other</option></select>
<label>Priority</label><select name="priority"><option value="">All</option><option>Low</option><option>Medium</option><option>High</option></select>
<label>Search</label><input name="q" value="<%= filters.q %>" placeholder="ID/summary/name"><br><br><button type="submit">Apply</button>
</form><hr><p><a href="/admin/reports">Reports</a></p><p><a href="/admin/export.csv">Export CSV</a></p><p><a href="/admin/logout">Logout</a></p></aside>
<main class="card"><h1>Tickets</h1><table class="table"><thead><tr><th>ID</th><th>Summary</th><th>Category</th><th>Priority</th><th>Status</th><th>Assignee</th><th>Created</th><th>Location</th></tr></thead><tbody><% tickets.forEach(t => { %><tr><td><a href="/admin/ticket/<%= t.ticket_id %>"><%= t.ticket_id %></a></td><td><%= t.summary %></td><td><%= t.category %></td><td><%= t.priority %></td><td><span class="badge status-<%= t.status %>"><%= t.status %></span></td><td><%= t.assignee || '-' %></td><td><%= t.created_at %></td><td><%= t.location %></td></tr><% }) %></tbody></table></main></div></div></body></html>